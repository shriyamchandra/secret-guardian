# Secret Guardian Backend Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# GOOGLE GEMINI API (Required for AI Remediation)
# ============================================================================
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# ============================================================================
# OPTIONAL CONFIGURATION
# ============================================================================

# Rate Limiting (requests per minute/hour)
# RATE_LIMIT_PER_MINUTE=10
# RATE_LIMIT_PER_HOUR=100

# Cache TTL in seconds (default: 3600 = 1 hour)
# CACHE_TTL=3600

# Scan timeout in seconds (default: 300 = 5 minutes)
# SCAN_TIMEOUT=300

# AI remediation tuning
# GEMINI_MODEL=gemini-2.0-flash
# MAX_AI_CALLS_PER_SCAN=5
# AI_CALL_TIMEOUT=30

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# Admin API Key (Required for /admin/* endpoints)
# NEVER commit the real key. Generate a long random string.
# Example: openssl rand -base64 32
ADMIN_API_KEY=change_me_to_a_long_random_secret

# ============================================================================
# DEPLOYMENT CONFIGURATION
# ============================================================================

# Frontend URL for CORS (required for production)
# Set this to your Vercel frontend URL (e.g., https://secret-guardian.vercel.app)
FRONTEND_URL=
